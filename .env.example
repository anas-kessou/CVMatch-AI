# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000

# Backend
APP_NAME=PFE CV Scoring API
APP_ENV=development
API_PREFIX=/api/v1

# Ollama local
#OLLAMA_ENABLED=true
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_TIMEOUT_SECONDS=15

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Config (for backend use if needed, frontend uses hardcoded or Vite envs)
FIREBASE_PROJECT_ID=cv-scoring-8aae1
FIREBASE_API_KEY=your_firebase_api_key_here 
FIREBASE_CREDENTIALS_PATH=backend/firebase-service-account.json

# Ingestion persistence (Option B: Firestore + local fallback)
INGESTION_STORAGE_MODE=auto
INGESTION_STORAGE_FILE=./data/ingestion_jobs.json

