# Backend example environment
PORT=8000
DEBUG=true
# Storage path for uploaded files (local dev)
UPLOAD_DIR=./data/uploads

# Neon/PostgreSQL database used for all application data and pgvector embeddings.
# Replace this with your Neon connection string. Keep the real value secret.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require

# Let Kaggle/dev startup create tables and vector indexes automatically.
# For production deployments with Alembic migrations, this can be false/unset.
AUTO_CREATE_TABLES=1
